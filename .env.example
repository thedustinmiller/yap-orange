# Database connection
DATABASE_URL=postgres://yap:yap@localhost:5432/yap

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# CLI configuration
YAP_SERVER_URL=http://localhost:3000

# Seed data for first-run import (server mode only)
# Not set: uses built-in tutorial content
# File path: imports that JSON file on first run
# "none" or empty: no seed data (production mode)
# YAP_SEED_FILE=fixtures/tutorial.json

# Logging level
RUST_LOG=yap_server=debug,yap_core=debug,tower_http=debug
